  },
  "components": {
    "schemas": {
      "UpdateProfileRequest": {
        "required": ["firstName", "lastName"],
        "type": "object",
        "properties": {
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "email": { "type": "string" },
          "mobileNumber": { "pattern": "^\\d{10}$", "type": "string" }
        }
      },
      "UserProfileResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "username": { "type": "string" },
          "email": { "type": "string" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "mobileNumber": { "type": "string" }
        }
      },
      "ChangePasswordRequest": {
        "required": ["confirmPassword", "currentPassword", "newPassword"],
        "type": "object",
        "properties": {
          "currentPassword": { "type": "string" },
          "newPassword": { "maxLength": 2147483647, "minLength": 6, "type": "string" },
          "confirmPassword": { "type": "string" }
        }
      },
      "UpiVerifyRequest": {
        "required": ["upiId"],
        "type": "object",
        "properties": { "upiId": { "pattern": "^[a-zA-Z0-9._-]+@[a-zA-Z][a-zA-Z0-9]+$", "type": "string" } }
      },
      "QrCodeRequest": {
        "required": ["amount", "merchantName", "merchantVpa"],
        "type": "object",
        "properties": {
          "merchantVpa": { "pattern": "^[a-zA-Z0-9._-]+@[a-zA-Z][a-zA-Z0-9]+$", "type": "string" },
          "merchantName": { "maxLength": 100, "minLength": 2, "type": "string" },
          "amount": { "type": "number" },
          "transactionNote": { "maxLength": 200, "minLength": 0, "type": "string" }
        }
      },
      "UpiPaymentRequest": {
        "required": ["amount", "fromUpi", "toUpi"],
        "type": "object",
        "properties": {
          "fromUpi": { "pattern": "^[a-zA-Z0-9._-]+@[a-zA-Z][a-zA-Z0-9]+$", "type": "string" },
          "toUpi": { "pattern": "^[a-zA-Z0-9._-]+@[a-zA-Z][a-zA-Z0-9]+$", "type": "string" },
          "amount": { "type": "number" },
          "note": { "type": "string" }
        }
      },
      "WithdrawRequest": {
        "required": ["accountNumber"],
        "type": "object",
        "properties": {
          "accountNumber": { "type": "string" },
          "amount": { "type": "number" },
          "description": { "type": "string" }
        }
      },
      "TransactionResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "format": "int64" },
          "transactionReference": { "type": "string" },
          "sourceAccount": { "type": "string" },
          "targetAccount": { "type": "string" },
          "amount": { "type": "number" },
          "balanceAfterTransaction": { "type": "number" },
          "type": { "type": "string", "enum": ["DEPOSIT", "WITHDRAWAL", "TRANSFER_OUT", "TRANSFER_IN", "BILL_PAYMENT", "REFUND"] },
          "status": { "type": "string" },
          "description": { "type": "string" },
          "transactionDate": { "type": "string", "format": "date-time" }
        }
      },
      "TransferRequest": {
        "required": ["fromAccount", "toAccount"],
        "type": "object",
        "properties": {
          "fromAccount": { "type": "string" },
          "toAccount": { "type": "string" },
          "amount": { "type": "number" },
          "description": { "type": "string" }
        }
      },
      "OtpVerificationRequest": {
        "type": "object",
        "properties": { "otp": { "type": "string" }, "transactionId": { "type": "string" } }
      },
      "DepositRequest": {
        "required": ["accountNumber"],
        "type": "object",
        "properties": {
          "accountNumber": { "type": "string" },
          "amount": { "type": "number" },
          "description": { "type": "string" }
        }
      },
      "RegisterRequest": {
        "required": ["email", "firstName", "lastName", "mobileNumber", "password", "username"],
        "type": "object",
        "properties": {
          "username": { "maxLength": 50, "minLength": 4, "type": "string" },
          "password": { "maxLength": 2147483647, "minLength": 6, "type": "string" },
          "email": { "type": "string" },
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "mobileNumber": { "pattern": "^\\d{10}$", "type": "string" }
        }
      },
      "RequestPasswordReset": {
        "required": ["confirmPassword", "newPassword", "token"],
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "newPassword": { "maxLength": 2147483647, "minLength": 6, "type": "string" },
          "confirmPassword": { "type": "string" }
        }
      },
      "LoginRequest": {
        "required": ["password", "username"],
        "type": "object",
        "properties": { "username": { "type": "string" }, "password": { "type": "string" } }
      },
      "JwtResponse": {
        "type": "object",
        "properties": {
          "token": { "type": "string" },
          "type": { "type": "string" },
          "id": { "type": "integer", "format": "int64" },
          "username": { "type": "string" },
          "email": { "type": "string" },
          "roles": { "type": "array", "items": { "type": "string" } }
        }
      },
      "ForgotPasswordRequest": {
        "required": ["email"],
        "type": "object",
        "properties": { "email": { "type": "string" } }
      },
      "CreateAccountRequest": {
        "required": ["accountType"],
        "type": "object",
        "properties": {
          "accountType": { "type": "string", "enum": ["SAVINGS", "CURRENT", "SALARY"] },
          "branch": { "type": "string" }
        }
      },
      "AccountResponse": {
        "type": "object",
        "properties": {
          "accountNumber": { "type": "string" },
          "accountType": { "type": "string", "enum": ["SAVINGS", "CURRENT", "SALARY"] },
          "balance": { "type": "number" },
          "status": { "type": "string", "enum": ["ACTIVE", "FROZEN", "INACTIVE", "CLOSED"] },
          "branch": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" },
          "ownerName": { "type": "string" }
        }
      },
      "PatchUserRequest": {
        "type": "object",
        "properties": {
          "firstName": { "type": "string" },
          "lastName": { "type": "string" },
          "email": { "type": "string" },
          "mobileNumber": { "type": "string" },
          "address": { "type": "string" }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": { "type": "http", "description": "JWT token obtained from login API", "scheme": "bearer", "bearerFormat": "JWT" }
    }
  }
}
