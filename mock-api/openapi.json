  "paths": {
    "/api/users/profile": {
      "get": {
        "tags": ["User Management"],
        "operationId": "getUserProfile",
        "responses": {
          "200": {
            "description": "OK",
            "content": { "*/*": { "schema": { "$ref": "#/components/schemas/UserProfileResponse" } } }
          }
        }
      },
      "put": {
        "tags": ["User Management"],
        "operationId": "updateProfile",
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateProfileRequest" } } },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": { "*/*": { "schema": { "$ref": "#/components/schemas/UserProfileResponse" } } }
          }
        }
      },
      "delete": {
        "tags": ["User Management"],
        "operationId": "deleteProfile",
        "parameters": [
          { "name": "confirmationCode", "in": "query", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "*/*": { "schema": { "type": "object" } } } }
        }
      },
      "patch": {
        "tags": ["User Management"],
        "operationId": "patchProfile",
        "requestBody": {
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/PatchUserRequest" } } },
          "required": true
        },
        "responses": {
          "200": { "description": "OK", "content": { "*/*": { "schema": { "type": "object" } } } }
        }
      }
    },
