      "get": {
        "tags": ["account-controller"],
        "operationId": "getAccountDetails",
        "parameters": [
          { "name": "accountNumber", "in": "path", "required": true, "schema": { "type": "string" } }
        ],
        "responses": {
          "200": { "description": "OK", "content": { "*/*": { "schema": { "$ref": "#/components/schemas/AccountResponse" } } } }
