        "responses": {
          "422": { "description": "Invalid input provided" },
          "200": {
            "description": "Successful login",
            "content": { "application/json": { "schema": { "$ref": "#/components/schemas/JwtResponse" } } }
          },
          "401": { "description": "Invalid credentials" }
        }
