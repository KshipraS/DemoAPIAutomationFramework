          { "name": "accountNumber", "in": "query", "required": true, "schema": { "type": "string" } },
          { "name": "fromDate", "in": "query", "required": false, "schema": { "type": "string", "format": "date" } },
          { "name": "toDate", "in": "query", "required": false, "schema": { "type": "string", "format": "date" } }
        ],
